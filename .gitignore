# ─── Foundry build artifacts ──────────────────────────────────────────────────
cache/
out/
broadcast/*/31337/
broadcast/**/dry-run/

# ─── Environment / secrets ────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ─── Node / npm (frontend tooling) ───────────────────────────────────────────
node_modules/
.pnp
.pnp.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── IDE / editor ─────────────────────────────────────────────────────────────
.vscode/
.idea/
*.iml
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ─── Hardhat (if ever mixed in) ───────────────────────────────────────────────
artifacts/
typechain/
typechain-types/

# ─── Coverage ─────────────────────────────────────────────────────────────────
coverage/
lcov.info

# ─── Deployment records (keep mainnet, ignore local) ─────────────────────────
broadcast/*/31337/
!/broadcast
!/broadcast/**

# ─── Solidity coverage ────────────────────────────────────────────────────────
.solcover.js

# ─── Lock files (optional — keep foundry.lock, ignore npm) ───────────────────
package-lock.json
yarn.lock
pnpm-lock.yaml
