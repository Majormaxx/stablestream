# =============================================================================
# StableStream — Environment Configuration
# Copy to .env and fill in real values before deploying.
# NEVER commit .env with real private keys.
# =============================================================================

# ── RPC Endpoints ─────────────────────────────────────────────────────────────

# Unichain Sepolia (testnet, chain ID 1301)
UNICHAIN_SEPOLIA_RPC=https://sepolia.unichain.org

# Unichain Mainnet (chain ID 130)
UNICHAIN_RPC=https://mainnet.unichain.org

# Reactive Network — Kopli testnet (chain ID 5318008)
REACTIVE_RPC=https://kopli-rpc.rnk.dev/

# ── Deployer Keys ─────────────────────────────────────────────────────────────
# Use Foundry's cast wallet or hardware wallet in production.
# The default key below is the well-known Hardhat/Foundry dev key — testnet only.

# Primary deployer (Unichain)
PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Reactive Network deployer (may be same or different key)
REACTIVE_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# ── Verification ──────────────────────────────────────────────────────────────

# Etherscan API key — works for Unichain via Etherscan API V2 (Uniscan is powered by Etherscan)
# One key covers Unichain (chain ID 130 / 1301) and 60+ other EVM chains.
# Obtain from: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Uniscan API key — set to the same Etherscan key above (Uniscan uses Etherscan API V2)
# Obtain from: https://uniscan.xyz/myapikey
UNISCAN_API_KEY=

# ── Deployed Contract Addresses (filled after deployment) ─────────────────────

# Unichain Sepolia
YIELD_ROUTER_ADDRESS=
AAVE_V3_ADAPTER_ADDRESS=
COMPOUND_V3_ADAPTER_ADDRESS=
STABLE_STREAM_HOOK_ADDRESS=
STABLE_STREAM_NFT_ADDRESS=

# Reactive Network
RANGE_MONITOR_RSC_ADDRESS=
